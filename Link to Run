kground: radial-gradient(circle, #ffb3d1, #ff6b9d); top: -120px; right: -100px; animation: float 8s ease-in-out infinite; } .hero::after { width: 380px; height: 380px; background: radial-gradient(circle, #ffd6e7, #ff9ec5); bottom: -80px; left: -60px; animation: float 10s ease-in-out infinite reverse; } @keyframes float { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-30px) scale(1.05); } } .hero-content { position: relative; z-index: 1; max-width: 700px; } .hero-badge { display: inline-block; background: rgba(255,107,157,0.15); border: 1px solid rgba(255,107,157,0.4); color: var(--pink-deep); font-size: 0.78rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; padding: 6px 18px; border-radius: 50px; margin-bottom: 22px; } .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 6vw, 3.8rem); line-height: 1.15; color: var(--dark); margin-bottom: 18px; } .hero h1 span { color: var(--pink); } .hero p { font-size: 1.05rem; color: var(--gray); line-height: 1.7; margin-bottom: 36px; } .hero-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; } .btn-primary { padding: 14px 32px; background: linear-gradient(135deg, var(--pink), var(--pink-deep)); color: white; border: none; border-radius: 50px; font-family: 'Poppins', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; box-shadow: 0 8px 24px rgba(255,107,157,0.45); transition: all 0.3s; text-decoration: none; display: inline-block; } .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(255,107,157,0.55); } .btn-secondary { padding: 14px 32px; background: white; color: var(--pink-deep); border: 2px solid var(--pink-soft); border-radius: 50px; font-family: 'Poppins', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.3s; text-decoration: none; display: inline-block; } .btn-secondary:hover { border-color: var(--pink); transform: translateY(-3px); box-shadow: 0 8p