lease be sure before you finalize your order.</p> </div> </div> <div class="guidelines-note"> 💌 &nbsp;Have questions before ordering? Just <strong>DM us</strong> on Messenger — we're always happy to help! </div> </section> <!-- ── ORDER ──────────────────────────────────────────── --> <section id="order"> <p class="section-label">Ready to Order?</p> <h2 class="section-title">Get Your Bouquet Today 🌸</h2> <div class="order-box"> <div class="order-icon">🛒</div> <h3 style="font-family:'Playfair Display',serif; margin-bottom:8px;">Your Selection</h3> <p style="color:var(--gray); font-size:0.9rem;">Pick a product from above, then message us below.</p> <div id="selectedProduct">No product selected yet 🌸</div> <button class="btn-primary" style="width:100%; padding:16px;" onclick="orderNow()"> Order via Messenger 💬 </button> <p class="order-note"> 💡 You'll be redirected to our Messenger to place your order. We'll confirm details, customization, and payment there. <strong>Remember: Payment First before we start processing!</strong> </p> </div> </section> <!-- ── FOOTER ─────────────────────────────────────────── --> <footer> <div class="footer-logo">🌸 Fuzzy Flower Boutique</div> <div class="social">📘 📸 🎵</div> <p>Handmade with love from the Philippines 🇵🇭</p> <p style="margin-top:8px; font-size:0.78rem; opacity:0.5;">© 2026 Fuzzy Flower Boutique. All rights reserved.</p> </footer> <!-- ── IMAGE MODAL ────────────────────────────────────── --> <div class="modal-overlay" id="modal" onclick="closeModal(event)"> <div class="modal-inner" onclick="event.stopPropagation()"> <button class="modal-close" onclick="closeModal()">✕</button> <img id="modalImg" src="" alt="Product Preview"> </div> </div> <!-- ── TOAST ──────────────────────────────────────────── --> <div class="toast" id="toast"></div> <!-- ── JAVASCRIPT ─────────────────────────────────────── --> <script> /* ── YOUR FACEBOOK MESSENGER LINK ── Replace the URL below with your classmate's actual FB page or Messenger link Example: https://m.me/YourPageName OR https://facebook.com/YourPageName */ const MESSENGER_LINK = "https://www.facebook.com/kaye.szn"; let selectedProduct = ""; let selectedBtnId = ""; /* scroll helpers */ function scrollToShop() { document.getElementById("products").scrollIntoView({ behavior: "smooth" }); } function scrollToOrder() { document.getElementById("order").scrollIntoView({ behavior: "smooth" }); } /* select product */ function selectProduct(product, btnId) { selectedProduct = product; /* reset all buttons */ document.querySelectorAll(".btn-select").forEach(b => { b.textContent = "Select 💖"; b.classList.remove("selected"); }); /* highlight chosen button */ const btn = document.getElementById(btnId); btn.textContent = "✓ Selected!"; btn.classList.add("selected"); selectedBtnId = btnId; /* update order box */ const box = document.getElementById("selectedProduct"); box.textContent = "Selected: " + product; box.classList.add("has-item"); showToast("Added: " + product + " 🌸"); scrollToOrder(); } /* order */ function orderNow() { if (!selectedProduct) { showToast("Please select a product first! 🌸"); scrollToShop(); return; } showToast("Redirecting to Messenger... 💬"); setTimeout(() => { window.open(MESSENGER_LINK + "?text=Hi! I want to order: " + encodeURIComponent(selectedProduct), "_blank"); }, 800); } /* modal */ function openModal(src) { document.getElementById("modalImg").src = src; document.getElementById("modal").classList.add("open"); document.body.style.overflow = "hidden"; } function closeModal(e) { if (!e || e.target === document.getElementById("modal")) { document.getElementById("modal").classList.remove("open"); document.body.style.overflow = ""; } } /* close modal with Escape key */ document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); }); /* toast */ function showToast(msg) { const t = document.getElementById("toast"); t.textContent = msg; t.classList.add("show"); setTimeout(() => t.classList.remove("show"), 2800); } /* animate cards on scroll */ const observer = new IntersectionObserver((entries) => { entries.forEach((entry, i) => { if (entry.isIntersecting) { setTimeout(() => { entry.target.style.opacity = "1"; entry.target.style.transform = "translateY(0)"; }, i * 80); observer.unobserve(entry.target); } }); }, { threshold: 0.1 }); document.querySelectorAll(".card, .feature-card").forEach(el => { el.style.opacity = "0"; el.style.transform = "translateY(30px)"; el.style.transition = "opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s, border-color 0.3s"; observer.observe(el); }); </script> </body> </html>
